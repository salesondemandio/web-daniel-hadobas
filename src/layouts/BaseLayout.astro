---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
} = Astro.props;

const canonicalClean = canonical.replace(/\/$/, '') || 'https://danielhadobas.com';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalClean} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalClean} />
  <meta property="og:site_name" content="Daniel Hadobas Solar" />

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <slot name="schema" />
</head>
<body class="min-h-screen flex flex-col">

  <!-- Urgency Bar -->
  <div class="urgency-banner text-white text-center text-xs sm:text-sm font-semibold py-2.5 px-4" role="alert">
    ⚡ Federal Solar Tax Credits May Expire — Lock In Your 30% Credit Now
    <a href="https://danielhadobas.com/sodsolarsavings" target="_blank" rel="noopener noreferrer" class="underline ml-2 font-bold hover:text-amber-300">
      Get Free Quote &rarr;
    </a>
  </div>

  <!-- Navigation -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-100 shadow-sm">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brand-orange to-solar-gold flex items-center justify-center shadow-md">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="4" fill="white"/>
            <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="white" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="font-display font-bold text-brand-dark text-lg leading-tight">
          Daniel Hadobas<br class="hidden sm:block" />
          <span class="text-brand-orange text-sm font-sans font-semibold">Solar</span>
        </span>
      </a>

      <!-- Nav links (desktop) -->
      <ul class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-600">
        <li><a href="/" class="hover:text-brand-orange transition-colors">Home</a></li>
        <li><a href="/solar-las-vegas" class="hover:text-brand-orange transition-colors">Las Vegas</a></li>
        <li><a href="/solar-california" class="hover:text-brand-orange transition-colors">California</a></li>
        <li><a href="/about" class="hover:text-brand-orange transition-colors">About</a></li>
        <li><a href="/blog" class="hover:text-brand-orange transition-colors">Blog</a></li>
      </ul>

      <!-- CTA -->
      <a
        href="https://danielhadobas.com/sodsolarsavings"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex items-center gap-2 bg-brand-orange text-white px-5 py-2.5 rounded-lg font-semibold text-sm cta-glow"
      >
        Get Free Quote
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden bg-white border-t border-slate-100 px-4 pb-4"
      role="navigation"
      aria-label="Mobile navigation"
    >
      <ul class="flex flex-col gap-1 pt-3 text-sm font-medium">
        <li><a href="/" class="block py-2 px-3 rounded-lg hover:bg-slate-50 hover:text-brand-orange transition-colors">Home</a></li>
        <li><a href="/solar-las-vegas" class="block py-2 px-3 rounded-lg hover:bg-slate-50 hover:text-brand-orange transition-colors">Las Vegas</a></li>
        <li><a href="/solar-california" class="block py-2 px-3 rounded-lg hover:bg-slate-50 hover:text-brand-orange transition-colors">California</a></li>
        <li><a href="/about" class="block py-2 px-3 rounded-lg hover:bg-slate-50 hover:text-brand-orange transition-colors">About</a></li>
        <li><a href="/blog" class="block py-2 px-3 rounded-lg hover:bg-slate-50 hover:text-brand-orange transition-colors">Blog</a></li>
        <li class="pt-2">
          <a
            href="https://danielhadobas.com/sodsolarsavings"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 bg-brand-orange text-white px-4 py-2.5 rounded-lg font-semibold"
          >
            Get Free Quote
          </a>
        </li>
      </ul>
    </div>
  </header>

  <!-- Page content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-brand-dark text-slate-300 mt-auto">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
        <!-- Brand column -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brand-orange to-solar-gold flex items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="4" fill="white"/>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <span class="font-display font-bold text-white text-lg">Daniel Hadobas Solar</span>
          </div>
          <p class="text-sm text-slate-400 leading-relaxed">
            Licensed Solar Energy Specialist serving Las Vegas, NV and California homeowners since 2020.
          </p>
        </div>

        <!-- Quick links -->
        <div>
          <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Service Areas</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/solar-las-vegas" class="hover:text-brand-orange transition-colors">Solar Las Vegas, NV</a></li>
            <li><a href="/solar-henderson-nv" class="hover:text-brand-orange transition-colors">Solar Henderson, NV</a></li>
            <li><a href="/solar-north-las-vegas" class="hover:text-brand-orange transition-colors">Solar North Las Vegas</a></li>
            <li><a href="/solar-california" class="hover:text-brand-orange transition-colors">Solar California</a></li>
            <li><a href="/solar-los-angeles" class="hover:text-brand-orange transition-colors">Solar Los Angeles</a></li>
            <li><a href="/solar-san-diego" class="hover:text-brand-orange transition-colors">Solar San Diego</a></li>
          </ul>
        </div>

        <!-- Contact + Trust -->
        <div>
          <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact &amp; Reviews</h3>
          <ul class="space-y-3 text-sm">
            <li>
              <a href="tel:7027654527" class="flex items-center gap-2 hover:text-brand-orange transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 0117 2.18 2 2 0 0119.08 4v3.09a2 2 0 01-1.42 1.93l-1.8.6a16 16 0 006.62 6.62l.6-1.8a2 2 0 011.92-1.42z"/></svg>
                (702) 765-4527
              </a>
            </li>
            <li class="flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Las Vegas, NV &amp; California
            </li>
            <li class="mt-2 pt-3 border-t border-slate-700">
              <div class="flex items-center gap-1 mb-1" aria-label="5 stars">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="#FCD34D"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="#FCD34D"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="#FCD34D"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="#FCD34D"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="#FCD34D"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </div>
              <p class="text-white font-bold">174 Five-Star Reviews</p>
              <p class="text-slate-400 text-xs mt-0.5">Verified Google Reviews</p>
            </li>
            <li class="flex gap-3 pt-2">
              <a href="https://www.facebook.com/profile.php?id=100089968135364" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-brand-orange transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              </a>
              <a href="https://www.instagram.com/hadobadass/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-brand-orange transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
              <a href="https://www.linkedin.com/in/daniel-hadobas" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-brand-orange transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              </a>
            </li>
          </ul>
        </div>
      </div>

      <div class="border-t border-slate-700 pt-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-slate-500">
        <p>Daniel Hadobas | Licensed Solar Agent | Las Vegas, NV &amp; California</p>
        <p>&copy; 2025 Daniel Hadobas Solar. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      const isOpen = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  </script>
</body>
</html>
