---
interface Step {
  title: string;
  description: string;
}

interface Props {
  headline?: string;
  steps: Step[];
}

const {
  headline = 'Go Solar in 3 Simple Steps',
  steps,
} = Astro.props;
---

<section class="py-16 bg-[#FAFAF8]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <div class="section-divider mx-auto mb-4"></div>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-3">{headline}</h2>
      <p class="text-slate-500 max-w-xl mx-auto">
        Daniel handles everything from your free savings analysis to final inspection. You just flip the switch.
      </p>
    </div>

    <!-- Steps grid -->
    <div class="relative grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Connecting line (desktop only) -->
      <div class="hidden md:block absolute top-[2.75rem] left-[16.67%] right-[16.67%] h-px bg-[#6AB745]/30" aria-hidden="true"></div>

      {steps.map((step, i) => (
        <div class="relative bg-white rounded-2xl p-8 border border-[#E8ECE4] shadow-[0_2px_8px_rgba(5,7,8,0.06)] hover:shadow-[0_12px_32px_rgba(5,7,8,0.10)] hover:-translate-y-0.5 transition-all duration-300">
          <!-- Numbered circle -->
          <div class="w-11 h-11 rounded-full bg-[#6AB745] flex items-center justify-center mb-6 shadow-md shadow-[#6AB745]/30 relative z-10">
            <span class="text-white font-bold text-base">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <h3 class="font-bold text-slate-900 text-lg mb-3">{step.title}</h3>
          <p class="text-slate-600 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- CTA under steps -->
    <div class="text-center mt-10">
      <a
        href="/#get-quote"
       
       
        class="inline-flex items-center gap-2 bg-brand-orange text-slate-900 px-8 py-4 rounded-lg font-bold cta-glow"
      >
        See My Monthly Savings
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
