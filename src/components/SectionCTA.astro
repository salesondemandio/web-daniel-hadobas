---
interface Props {
  headline: string;
  subheadline?: string;
  buttonText: string;
  buttonHref?: string;
}

const {
  headline,
  subheadline,
  buttonText,
  buttonHref = '/#get-quote',
} = Astro.props;
---

<section class="relative py-20 px-4 overflow-hidden" style="background-color:#6AB745;">
  <!-- Sunburst pattern (recurring brand fingerprint) -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.08]" aria-hidden="true">
    <svg width="900" height="900" viewBox="0 0 600 600" fill="none">
      <circle cx="300" cy="300" r="120" fill="#FFFFFF"/>
      {Array.from({ length: 24 }).map((_, i) => {
        const angle = (i * 360) / 24;
        const rad = (angle * Math.PI) / 180;
        const x1 = 300 + Math.cos(rad) * 140;
        const y1 = 300 + Math.sin(rad) * 140;
        const x2 = 300 + Math.cos(rad) * 320;
        const y2 = 300 + Math.sin(rad) * 320;
        return <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" />;
      })}
    </svg>
  </div>

  <div class="relative max-w-3xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-white/15 border border-white/30 text-white rounded-full px-4 py-1.5 text-xs font-semibold mb-6 backdrop-blur-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
      3 Spots Left for May
    </div>
    <h2 class="font-display text-3xl sm:text-5xl text-white mb-4 leading-tight">{headline}</h2>
    {subheadline && (
      <p class="text-white/90 mb-8 leading-relaxed max-w-xl mx-auto text-lg">{subheadline}</p>
    )}
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={buttonHref}
        class="inline-flex items-center gap-2 bg-white text-[#050708] px-8 py-4 rounded-lg font-bold text-base shadow-[0_8px_24px_rgba(5,7,8,0.20)] hover:-translate-y-0.5 hover:shadow-[0_12px_32px_rgba(5,7,8,0.28)] transition-all duration-200"
      >
        {buttonText}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="tel:+17029416894" class="text-white font-semibold hover:text-white/80 transition-colors flex items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 0117 2.18 2 2 0 0119.08 4v3.09a2 2 0 01-1.42 1.93l-1.8.6a16 16 0 006.62 6.62l.6-1.8a2 2 0 011.92-1.42z"/></svg>
        Call (702) 941-6894
      </a>
    </div>
  </div>
</section>
