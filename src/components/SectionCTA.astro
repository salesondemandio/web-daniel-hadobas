---
interface Props {
  headline: string;
  subheadline?: string;
  buttonText: string;
  buttonHref?: string;
}

const {
  headline,
  subheadline,
  buttonText,
  buttonHref = 'https://danielhadobas.com/sodsolarsavings',
} = Astro.props;
---

<section class="bg-gradient-to-br from-brand-dark to-slate-800 py-20 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-brand-orange/20 border border-brand-orange/30 text-brand-orange rounded-full px-4 py-1.5 text-xs font-semibold mb-6">
      Limited Spots Available This Month
    </div>
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">{headline}</h2>
    {subheadline && (
      <p class="text-slate-300 mb-8 leading-relaxed max-w-xl mx-auto">{subheadline}</p>
    )}
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={buttonHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-brand-orange text-white px-8 py-4 rounded-lg font-bold text-base cta-glow"
      >
        {buttonText}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="tel:+17027654527" class="text-white font-semibold hover:text-brand-orange transition-colors flex items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 0117 2.18 2 2 0 0119.08 4v3.09a2 2 0 01-1.42 1.93l-1.8.6a16 16 0 006.62 6.62l.6-1.8a2 2 0 011.92-1.42z"/></svg>
        Call (702) 765-4527
      </a>
    </div>
  </div>
</section>
