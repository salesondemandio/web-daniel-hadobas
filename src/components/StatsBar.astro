---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<div class="bg-brand-dark rounded-2xl px-4 py-8 sm:py-10">
  <div class={`grid grid-cols-1 sm:grid-cols-${Math.min(stats.length, 4)} gap-6 max-w-4xl mx-auto`}>
    {stats.map((stat, i) => (
      <div class="text-center group relative">
        <p class="font-display text-3xl sm:text-4xl font-bold text-brand-orange group-hover:scale-110 transition-transform duration-200 inline-block">
          {stat.value}
        </p>
        <p class="text-slate-400 text-sm mt-1 font-medium">{stat.label}</p>
        {i < stats.length - 1 && (
          <div class="hidden sm:block absolute right-0 top-1/2 -translate-y-1/2 w-px h-8 bg-slate-700" aria-hidden="true"></div>
        )}
      </div>
    ))}
  </div>
</div>
