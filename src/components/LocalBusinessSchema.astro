---
interface Props {
  city: string;
  state: string;
  description?: string;
  slug?: string;
}

const {
  city,
  state,
  description = `Daniel Hadobas is a licensed solar energy specialist serving ${city}, ${state} homeowners. Get $0 down solar with the 30% federal tax credit.`,
  slug,
} = Astro.props;

const citySlug = slug || `solar-${city.toLowerCase().replace(/\s+/g, '-')}-${state.toLowerCase()}`;
const pageUrl = slug === 'home' ? 'https://danielhadobas.com' : `https://danielhadobas.com/${citySlug}`;

const geoCoords: Record<string, { latitude: number; longitude: number }> = {
  'Las Vegas': { latitude: 36.1699, longitude: -115.1398 },
  'Henderson': { latitude: 36.0397, longitude: -114.9817 },
  'North Las Vegas': { latitude: 36.1988, longitude: -115.1175 },
  'Los Angeles': { latitude: 34.0522, longitude: -118.2437 },
  'San Diego': { latitude: 32.7157, longitude: -117.1611 },
  'Riverside': { latitude: 33.9806, longitude: -117.3755 },
  'Summerlin': { latitude: 36.1560, longitude: -115.3200 },
  'Green Valley': { latitude: 36.0153, longitude: -115.0633 },
};

const schema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  "name": `Daniel Hadobas Solar — ${city}, ${state}`,
  "description": description,
  "url": pageUrl,
  "telephone": "+17027654527",
  "priceRange": "$$$",
  "image": "https://danielhadobas.com/images/daniel-hadobas.jpg",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city,
    "addressRegion": state,
    "addressCountry": "US"
  },
  "geo": geoCoords[city] ? {
    "@type": "GeoCoordinates",
    "latitude": geoCoords[city].latitude,
    "longitude": geoCoords[city].longitude
  } : undefined,
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "08:00",
    "closes": "19:00"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "174",
    "bestRating": "5",
    "worstRating": "1"
  },
  "sameAs": [
    "https://www.facebook.com/profile.php?id=100089968135364",
    "https://www.instagram.com/hadobadass/",
    "https://www.linkedin.com/in/daniel-hadobas"
  ]
};

// Remove undefined values
const cleanSchema = JSON.parse(JSON.stringify(schema));
---

<script type="application/ld+json" set:html={JSON.stringify(cleanSchema)} />
