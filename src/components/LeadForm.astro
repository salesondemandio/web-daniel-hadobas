---
// Lead capture form — submits to /api/lead → GHL
---

<section class="py-16 bg-brand-dark" id="get-quote">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-8">
      <p class="text-brand-orange font-semibold text-sm uppercase tracking-widest mb-2">Free Solar Analysis</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-3">See How Much You Can Save</h2>
      <p class="text-slate-400 text-base">Takes 60 seconds. No credit check. Daniel calls you within the hour.</p>
    </div>

    <form id="lead-form" class="bg-slate-800/60 border border-slate-700 rounded-2xl p-8 space-y-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="lf-name" class="block text-sm font-semibold text-slate-300 mb-1.5">Full Name *</label>
          <input
            id="lf-name"
            name="name"
            type="text"
            required
            placeholder="Jane Smith"
            class="w-full bg-slate-900 border border-slate-600 text-white placeholder-slate-500 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition"
          />
        </div>
        <div>
          <label for="lf-phone" class="block text-sm font-semibold text-slate-300 mb-1.5">Phone *</label>
          <input
            id="lf-phone"
            name="phone"
            type="tel"
            required
            placeholder="(702) 555-0100"
            class="w-full bg-slate-900 border border-slate-600 text-white placeholder-slate-500 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition"
          />
        </div>
      </div>

      <div>
        <label for="lf-email" class="block text-sm font-semibold text-slate-300 mb-1.5">Email</label>
        <input
          id="lf-email"
          name="email"
          type="email"
          placeholder="you@email.com"
          class="w-full bg-slate-900 border border-slate-600 text-white placeholder-slate-500 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition"
        />
      </div>

      <div>
        <label for="lf-address" class="block text-sm font-semibold text-slate-300 mb-1.5">Home Address</label>
        <input
          id="lf-address"
          name="address"
          type="text"
          placeholder="123 Main St, Las Vegas, NV"
          class="w-full bg-slate-900 border border-slate-600 text-white placeholder-slate-500 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition"
        />
      </div>

      <div>
        <label for="lf-bill" class="block text-sm font-semibold text-slate-300 mb-1.5">Monthly Electric Bill</label>
        <select
          id="lf-bill"
          name="electricBill"
          class="w-full bg-slate-900 border border-slate-600 text-slate-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition"
        >
          <option value="">Select your range</option>
          <option value="$100–$150">$100 – $150</option>
          <option value="$150–$200">$150 – $200</option>
          <option value="$200–$300">$200 – $300</option>
          <option value="$300–$400">$300 – $400</option>
          <option value="$400+">$400+</option>
        </select>
      </div>

      <button
        type="submit"
        id="lf-submit"
        class="w-full bg-brand-orange text-white font-bold py-4 rounded-lg text-base cta-glow hover:brightness-110 transition disabled:opacity-60 disabled:cursor-not-allowed"
      >
        Get My Free Solar Savings Analysis
      </button>

      <p class="text-center text-xs text-slate-500">
        No obligation. No hard sell. Daniel calls — not a call center.
      </p>
    </form>

    <!-- Success state -->
    <div id="lead-success" class="hidden bg-slate-800/60 border border-green-600/40 rounded-2xl p-10 text-center">
      <div class="w-14 h-14 rounded-full bg-green-600/20 flex items-center justify-center mx-auto mb-4">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>
      <h3 class="text-white font-bold text-xl mb-2">You're on Daniel's List</h3>
      <p class="text-slate-400 text-sm" id="lead-success-msg">He'll be in touch within the hour to walk you through your savings estimate.</p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const success = document.getElementById('lead-success') as HTMLDivElement;
  const successMsg = document.getElementById('lead-success-msg') as HTMLParagraphElement;
  const submitBtn = document.getElementById('lf-submit') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json() as { success: boolean; error?: string };

      if (json.success) {
        form.classList.add('hidden');
        success.classList.remove('hidden');
        const name = (data.name as string)?.split(' ')[0];
        if (name) successMsg.textContent = `Thanks, ${name}! Daniel will call you within the hour.`;
      } else {
        alert(json.error || 'Something went wrong. Please call (702) 765-4527 directly.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Get My Free Solar Savings Analysis';
      }
    } catch {
      alert('Connection error. Please call (702) 765-4527 directly.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Get My Free Solar Savings Analysis';
    }
  });
</script>
