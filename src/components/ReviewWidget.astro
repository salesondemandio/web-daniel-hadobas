---
import { googleReviews } from '../data/reviews';
const reviews = googleReviews.map(r => ({ name: r.author, text: r.text, relative_time: r.relative_time }));
---

<!-- Header row -->
<div class="flex flex-col sm:flex-row items-center justify-between gap-6 mb-10">
  <div class="text-center sm:text-left">
    <div class="flex items-center gap-2 mb-1" aria-label="5 out of 5 stars">
      {Array.from({ length: 5 }).map(() => (
        <svg width="24" height="24" viewBox="0 0 24 24" fill="#FCD34D" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
      <span class="text-4xl font-bold text-brand-dark ml-1">5.0</span>
    </div>
    <p class="text-slate-600 font-medium">174 Verified Google Reviews</p>
  </div>
  <a
    href="https://www.google.com/maps/place/Daniel+at+Sunsolar+Solutions/@36.1699,-115.1398,15z/data=!4m6!3m5!1s0x80c8c432b48b1c4d:0x7c3bc8df3e6b8d1a!8m2!3d36.1699!4d-115.1398!16s%2Fg%2F11t4s_5zkm"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 bg-brand-orange text-white px-6 py-3 rounded-lg font-bold cta-glow text-sm"
  >
    See All Reviews
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
  </a>
</div>

<!-- Review cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  {reviews.map((review) => (
    <article class="bg-white rounded-2xl p-6 shadow-md border border-slate-100 flex flex-col gap-4 hover:shadow-lg transition-shadow duration-200">
      <!-- Stars -->
      <div class="flex items-center gap-0.5" aria-label="5 stars">
        {Array.from({ length: 5 }).map(() => (
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#FCD34D" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        ))}
      </div>
      <!-- Quote -->
      <blockquote class="text-slate-700 text-sm leading-relaxed flex-1">
        "{review.text}"
      </blockquote>
      <!-- Reviewer -->
      <footer class="flex items-center justify-between">
        <div>
          <p class="font-bold text-brand-dark text-sm">{review.name}</p>
          <p class="text-xs text-slate-400 mt-0.5">Verified Google Review · {review.relative_time}</p>
        </div>
        <!-- Google G icon -->
        <svg width="20" height="20" viewBox="0 0 24 24" aria-label="Google" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
      </footer>
    </article>
  ))}
</div>
