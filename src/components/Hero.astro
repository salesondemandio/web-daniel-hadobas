---
interface Props {
  headline: string;
  subheadline: string;
  ctaText: string;
  ctaHref?: string;
}

const {
  headline,
  subheadline,
  ctaText,
  ctaHref = 'https://danielhadobas.com/sodsolarsavings',
} = Astro.props;
---

<section class="relative bg-brand-dark overflow-hidden noise-overlay">
  <!-- Animated sun background -->
  <div class="absolute inset-0 flex items-center justify-end pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="sun-rays opacity-10 mr-[-10%] mt-[-10%]">
      <svg width="600" height="600" viewBox="0 0 600 600" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="300" cy="300" r="120" fill="#F97316" opacity="0.8"/>
        {Array.from({ length: 16 }).map((_, i) => {
          const angle = (i * 360) / 16;
          const rad = (angle * Math.PI) / 180;
          const x1 = 300 + Math.cos(rad) * 140;
          const y1 = 300 + Math.sin(rad) * 140;
          const x2 = 300 + Math.cos(rad) * 290;
          const y2 = 300 + Math.sin(rad) * 290;
          return (
            <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="#F97316" stroke-width="3" stroke-linecap="round" />
          );
        })}
      </svg>
    </div>
  </div>

  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-r from-brand-dark via-brand-dark/95 to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 sm:py-28 lg:py-36">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Left: Copy -->
      <div>
        <!-- Urgency badge -->
        <div class="inline-flex items-center gap-2 bg-brand-orange/20 border border-brand-orange/30 text-brand-orange rounded-full px-4 py-1.5 text-xs font-semibold mb-6 fade-up fade-up-delay-1">
          <div class="w-1.5 h-1.5 rounded-full bg-brand-orange animate-pulse"></div>
          Incentives Ending Soon — Lock In 30% Tax Credit
        </div>

        <!-- H1 -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-[1.08] mb-6 fade-up fade-up-delay-2">
          {headline}
        </h1>

        <p class="text-slate-300 text-lg leading-relaxed mb-6 fade-up fade-up-delay-3">
          {subheadline}
        </p>

        <!-- Stars -->
        <div class="flex items-center gap-2 mb-8 fade-up fade-up-delay-3">
          <div class="flex items-center gap-0.5" aria-label="5 out of 5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#FCD34D" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <span class="text-slate-300 text-sm font-medium">174 Five-Star Reviews</span>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-start gap-4 fade-up fade-up-delay-4">
          <a
            href={ctaHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-brand-orange text-white px-8 py-4 rounded-lg font-bold text-base cta-glow"
          >
            {ctaText}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a
            href="tel:7027654527"
            class="inline-flex items-center gap-2 text-white font-semibold hover:text-brand-orange transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 0117 2.18 2 2 0 0119.08 4v3.09a2 2 0 01-1.42 1.93l-1.8.6a16 16 0 006.62 6.62l.6-1.8a2 2 0 011.92-1.42z"/></svg>
            (702) 765-4527
          </a>
        </div>

        <!-- Trust signals -->
        <div class="flex flex-wrap items-center gap-4 mt-8 text-xs text-slate-400">
          <span class="flex items-center gap-1.5">
            <svg width="14" height="14" fill="#22c55e" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Licensed &amp; Insured
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="14" height="14" fill="#22c55e" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            $0 Down — No Hidden Fees
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="14" height="14" fill="#22c55e" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            25-Year Panel Warranty
          </span>
        </div>
      </div>

      <!-- Right: Photo / Placeholder -->
      <div class="hidden lg:flex justify-center items-center fade-up fade-up-delay-2">
        <div class="relative">
          <!-- Photo with orange accent border -->
          <div class="w-80 h-96 rounded-2xl overflow-hidden border-4 border-brand-orange shadow-2xl bg-slate-700 flex items-center justify-center">
            <img
              src="/images/daniel.jpg"
              alt="Daniel Hadobas — Las Vegas Solar Expert"
              class="w-full h-full object-cover object-top"
              loading="eager"
            />
          </div>
          <!-- Floating badge: Local since 1996 -->
          <div class="absolute -bottom-4 -left-6 bg-white rounded-xl px-4 py-3 shadow-xl border border-slate-100">
            <p class="text-xs text-slate-500 font-medium">Las Vegas Native</p>
            <p class="text-brand-dark font-bold text-sm">Since 1996</p>
          </div>
          <!-- Floating badge: Reviews -->
          <div class="absolute -top-4 -right-6 bg-brand-orange rounded-xl px-4 py-3 shadow-xl">
            <div class="flex items-center gap-0.5 mb-0.5" aria-label="5 stars">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="#FCD34D"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="#FCD34D"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="#FCD34D"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="#FCD34D"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="#FCD34D"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="text-white font-bold text-xs">174 Reviews</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
