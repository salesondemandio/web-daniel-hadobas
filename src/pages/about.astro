---
import BaseLayout from '../layouts/BaseLayout.astro';
import PersonSchema from '../components/PersonSchema.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import CTAButton from '../components/CTAButton.astro';
import ReviewWidget from '../components/ReviewWidget.astro';
---

<BaseLayout
  title="About Daniel Hadobas | Licensed Solar Agent Las Vegas"
  description="Meet Daniel Hadobas — Las Vegas's top-rated solar agent. Licensed solar specialist with Sunder Energy. 174 five-star reviews and counting."
>
  <Fragment slot="schema">
    <PersonSchema />
    <LocalBusinessSchema city="Las Vegas" state="NV" slug="about" />
  </Fragment>

  <!-- Hero -->
  <section class="bg-brand-dark py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="section-divider mx-auto mb-6"></div>
      <h1 class="font-display text-4xl sm:text-5xl font-black text-white mb-4">
        About <span class="text-brand-orange">Daniel Hadobas</span>
      </h1>
      <p class="text-slate-300 text-lg max-w-xl mx-auto">
        Licensed Solar Energy Specialist · Sunder Energy · Las Vegas, NV &amp; California
      </p>
    </div>
  </section>

  <!-- Bio section -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <!-- Photo -->
        <div class="rounded-2xl overflow-hidden aspect-[4/5] bg-gradient-to-br from-solar-cream to-amber-100 border border-amber-200">
          <img
            src="/images/daniel-hadobas.jpg"
            alt="Daniel Hadobas — Licensed Solar Energy Specialist, Las Vegas NV"
            class="w-full h-full object-cover"
            width="480"
            height="600"
            loading="eager"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <div class="hidden w-full h-full items-center justify-center text-center p-8">
            <div>
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="mx-auto mb-3 text-amber-300" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              <p class="text-sm font-medium text-amber-500">Daniel Hadobas</p>
              <p class="text-xs text-amber-400 mt-1">Licensed Solar Specialist</p>
            </div>
          </div>
        </div>

        <!-- Bio text -->
        <div>
          <h2 class="font-display text-2xl font-bold text-brand-dark mb-4">
            Las Vegas's Most Trusted Solar Specialist
          </h2>
          <div class="section-divider mb-6"></div>

          <div class="prose prose-slate max-w-none text-slate-600 space-y-4 text-[15px] leading-relaxed">
            <p>
              Daniel Hadobas is a licensed solar energy specialist based in Las Vegas, NV,
              serving homeowners throughout the greater Las Vegas valley and across California.
              As an independent agent with <strong>Sunder Energy</strong> — one of America's
              highest-rated residential solar companies — Daniel brings a no-pressure,
              education-first approach to going solar.
            </p>
            <p>
              With over <strong>174 five-star Google reviews</strong>, Daniel has built
              a reputation for transparency, reliability, and delivering real, measurable
              savings for his clients. Many of his customers see their monthly NV Energy
              bills drop from $250–$400 to nearly zero — with no money down.
            </p>
            <p>
              Daniel handles everything from your initial savings analysis to post-install
              monitoring. He coordinates permits, HOA approvals, utility interconnection,
              and provides ongoing support to make sure your system performs as promised
              for decades to come.
            </p>
            <p>
              Whether you're a homeowner in Summerlin, Henderson, or Southern California,
              Daniel will design a custom solar system that maximizes your savings and
              locks in your energy rate before utility prices rise again.
            </p>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <CTAButton text="Get Free Savings Quote" size="lg" />
            <a href="tel:7027654527" class="inline-flex items-center gap-2 font-semibold text-brand-dark hover:text-brand-orange transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 017 2.18 2 2 0 019.09 4v3.09a2 2 0 01-1.42 1.93l-1.8.6a16 16 0 006.62 6.62l.6-1.8a2 2 0 011.92-1.42z"/></svg>
              (702) 765-4527
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials -->
  <section class="bg-slate-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10">
        <div class="section-divider mx-auto mb-4"></div>
        <h2 class="font-display text-3xl font-bold text-brand-dark">Credentials &amp; Affiliations</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { title: 'Licensed Solar Agent', detail: 'State of Nevada &amp; California', icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z' },
          { title: 'Sunder Energy', detail: 'Top-Rated Solar Provider', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
          { title: '174 Five-Star Reviews', detail: 'Google Verified', icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z' },
        ].map((cred) => (
          <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm text-center">
            <div class="w-12 h-12 rounded-xl bg-brand-orange/10 flex items-center justify-center mx-auto mb-4">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={cred.icon}/>
              </svg>
            </div>
            <h3 class="font-semibold text-brand-dark">{cred.title}</h3>
            <p class="text-sm text-slate-500 mt-1" set:html={cred.detail}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="section-divider mx-auto mb-4"></div>
      <h2 class="font-display text-3xl font-bold text-brand-dark mb-10">What Homeowners Say</h2>
      <ReviewWidget />
    </div>
  </section>
</BaseLayout>
