---
import BaseLayout from '../layouts/BaseLayout.astro';
import PersonSchema from '../components/PersonSchema.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import CTAButton from '../components/CTAButton.astro';
import ReviewWidget from '../components/ReviewWidget.astro';
---

<BaseLayout
  title="About Daniel Hadobas | Licensed Solar Agent Las Vegas"
  description="Meet Daniel Hadobas — Las Vegas's top-rated solar agent. Licensed solar specialist with 174 five-star reviews and counting. Built on referrals, not call centers."
  keywords="Daniel Hadobas, Las Vegas solar agent, licensed solar specialist Nevada, Daniel Hadobas solar reviews, independent solar agent Las Vegas"
>
  <Fragment slot="schema">
    <PersonSchema />
    <LocalBusinessSchema city="Las Vegas" state="NV" slug="about" />
  </Fragment>

  <!-- Hero -->
  <section class="bg-[#FAFAF8] py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="section-divider mx-auto mb-6"></div>
      <h1 class="font-display text-4xl sm:text-5xl font-black text-slate-900 mb-4">
        About <span class="text-brand-orange">Daniel Hadobas</span>
      </h1>
      <p class="text-slate-600 text-lg max-w-xl mx-auto">
        Licensed Solar Energy Specialist · Las Vegas, NV &amp; California
      </p>
    </div>
  </section>

  <!-- Bio section -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <!-- Photo -->
        <div class="rounded-2xl overflow-hidden aspect-[4/5] bg-gradient-to-br from-solar-cream to-amber-100 border border-amber-500/30">
          <img
            src="/images/daniel-hadobas.jpg"
            alt="Daniel Hadobas — Licensed Solar Energy Specialist, Las Vegas NV"
            class="w-full h-full object-cover"
            width="480"
            height="600"
            loading="eager"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <div class="hidden w-full h-full items-center justify-center text-center p-8">
            <div>
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="mx-auto mb-3 text-amber-300" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              <p class="text-sm font-medium text-amber-500">Daniel Hadobas</p>
              <p class="text-xs text-amber-400 mt-1">Licensed Solar Specialist</p>
            </div>
          </div>
        </div>

        <!-- Bio text -->
        <div>
          <h2 class="font-display text-3xl font-bold text-slate-900 mb-4 leading-tight">
            The solar guy who answers his own phone.
          </h2>
          <div class="section-divider mb-6"></div>

          <div class="prose prose-slate max-w-none text-slate-700 space-y-4 text-[15px] leading-relaxed">
            <p>
              Daniel Hadobas isn't a call-center rep. He's a Las Vegas resident, a licensed solar energy specialist,
              and the agent <strong>174 homeowners</strong> have left five-star Google reviews for —
              with zero one-stars on record.
            </p>
            <p>
              Daniel partners with multiple top-rated, licensed installers across Nevada and California — picking
              the right one for your house, your roof, and your service area. The work that earns the reviews is Daniel's:
              he sizes the system, runs the math against your real utility bill, coordinates permits, HOA approval,
              and utility interconnection, and stays on the account after the install.
            </p>
            <p>
              By his second full year selling solar he hit <strong>178 installs</strong> — the top 1% of the
              industry — without buying leads or running a sales floor. Every appointment came from a referral
              or a Google review, and that's still how he runs.
            </p>
            <p>
              On the call: he'll tell you what your monthly savings actually look like, what the 30% federal
              tax credit means for your tax return, whether battery storage makes sense for your house,
              and whether solar is worth doing at all for your situation. If the math doesn't work, he'll
              say so.
            </p>
          </div>

          <!-- Trustpilot critic quote -->
          <blockquote class="mt-6 border-l-4 border-[#6AB745] pl-5 py-3 bg-[#F0F2EE] rounded-r-lg">
            <p class="text-slate-900 font-medium italic mb-1 text-[15px]">
              "The salesman Daniel was great — no pressure, very knowledgeable, and friendly."
            </p>
            <footer class="text-slate-500 text-xs">
              — Rod D., verified Las Vegas customer (Trustpilot, March 2025) · A critical review of the
              office staff that still went out of its way to praise Daniel by name.
            </footer>
          </blockquote>

          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <CTAButton text="Get Free Savings Quote" size="lg" />
            <a href="tel:+17029416894" class="inline-flex items-center gap-2 font-semibold text-slate-900 hover:text-brand-orange transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 017 2.18 2 2 0 019.09 4v3.09a2 2 0 01-1.42 1.93l-1.8.6a16 16 0 006.62 6.62l.6-1.8a2 2 0 011.92-1.42z"/></svg>
              (702) 941-6894
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials -->
  <section class="bg-[#FAFAF8] py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10">
        <div class="section-divider mx-auto mb-4"></div>
        <h2 class="font-display text-3xl font-bold text-slate-900">Credentials &amp; Affiliations</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { title: 'Top 1% Nationally', detail: '178 installs in his second year', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
          { title: '174 Five-Star Reviews', detail: 'Google verified · zero one-stars', icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z' },
          { title: 'Licensed Solar Agent', detail: 'Nevada &amp; California · independent of any single installer', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
        ].map((cred) => (
          <div class="bg-white rounded-2xl p-6 border border-[#E8ECE4] shadow-[0_4px_16px_rgba(5,7,8,0.06)] text-center">
            <div class="w-12 h-12 rounded-xl bg-[#6AB745]/10 flex items-center justify-center mx-auto mb-4">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#3F6E29" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={cred.icon}/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-900">{cred.title}</h3>
            <p class="text-sm text-slate-500 mt-1" set:html={cred.detail}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="section-divider mx-auto mb-4"></div>
      <h2 class="font-display text-3xl font-bold text-slate-900 mb-10">What Homeowners Say</h2>
      <ReviewWidget />
    </div>
  </section>
</BaseLayout>
