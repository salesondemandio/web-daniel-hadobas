---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhyDaniel from '../components/WhyDaniel.astro';
import ReviewWidget from '../components/ReviewWidget.astro';
import SectionCTA from '../components/SectionCTA.astro';
import PersonSchema from '../components/PersonSchema.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import FAQSection from '../components/FAQSection.astro';
import LeadForm from '../components/LeadForm.astro';

const stats = [
  { value: '290+', label: 'Sunny Days Per Year in Las Vegas' },
  { value: '174', label: 'Five-Star Google Reviews' },
  { value: '$0', label: 'Down To Get Started' },
];

const howItWorksSteps = [
  {
    title: 'Free Savings Analysis',
    description: 'Daniel reviews your utility bills and designs a custom solar system sized for your home and energy usage. Zero cost, zero obligation.',
  },
  {
    title: 'Permits & Installation',
    description: "Daniel coordinates permits, HOA approvals, and schedules your installation with a certified, licensed installer. Average install: 1–2 days.",
  },
  {
    title: 'Start Saving Immediately',
    description: 'Once your utility approves interconnection, your system goes live. Watch your bill drop from day one — and lock in rates for 25 years.',
  },
];

const homeFaqs = [
  {
    question: 'How much does solar cost in Las Vegas?',
    answer: 'Most Las Vegas homeowners go solar for $0 down with financing. The average system size is 6–8kW, costing $15,000–$22,000 before incentives. After the 30% federal tax credit, your net cost drops to $10,500–$15,400. Your actual savings depend on your current NV Energy bill, your roof, and your usage — Daniel runs the math against your real bill before recommending anything.',
  },
  {
    question: 'What is the 30% federal solar tax credit?',
    answer: 'The Inflation Reduction Act provides a 30% Investment Tax Credit (ITC) on the full cost of your solar installation. If your system costs $18,000, you receive a $5,400 credit directly off your federal taxes. This credit is available through at least 2032 but may be subject to future legislative changes. The credit is non-refundable — it reduces the taxes you owe but does not create a refund if you owe less than the credit amount.',
  },
  {
    question: 'How does NV Energy net metering work?',
    answer: "NV Energy's net metering program lets you sell excess solar energy back to the grid at approximately 75% of retail rate. When your panels produce more than you use, the surplus earns credits that offset the energy you pull from the grid at night. This significantly reduces or eliminates your electric bill. Las Vegas's 290+ sunny days per year make net metering especially valuable.",
  },
  {
    question: 'Is Daniel Hadobas a licensed solar contractor?',
    answer: "Daniel is a licensed solar energy specialist serving homeowners across Nevada and California. He handles permitting, HOA approvals, utility interconnection, and monitors your system post-install to ensure everything performs as promised. He has earned 174 five-star reviews from verified homeowners.",
  },
  {
    question: 'How many solar panels do I need for a Las Vegas home?',
    answer: 'Most Las Vegas homes (1,500–2,500 sq ft) need 18–28 panels to offset 80–100% of their electric usage. The exact number depends on your average monthly kWh usage, roof orientation, and shading. Daniel analyzes your last 12 months of utility bills to design a system sized precisely for your home — no guessing, no overselling.',
  },
  {
    question: 'Does solar work in Las Vegas heat?',
    answer: 'Yes — Las Vegas is one of the best solar markets in the US. While high temperatures slightly reduce panel output (panels are rated at 25°C), Las Vegas gets over 290 sunny days per year, far more than the national average of 205. The sheer volume of daily sunlight more than compensates for any heat-related efficiency dip. Las Vegas homeowners consistently see the highest solar production rates in the country.',
  },
  {
    question: 'What company does Daniel Hadobas work for?',
    answer: 'Daniel is a licensed solar energy specialist who partners with top-rated, licensed installers in your service area. He handles your account personally from quote to post-install support — permitting, HOA approvals, utility interconnection, and ongoing monitoring after install.',
  },
  {
    question: 'What happens to my solar if I sell my house?',
    answer: "If you own your solar system outright or financed it with a loan, it transfers with the house and typically adds $15,000–$25,000 to your home's appraised value. Studies show solar homes sell faster than non-solar homes. If you have a lease or PPA (which Daniel does not recommend), the new buyer must qualify to take over the contract or you may need to buy it out at closing.",
  },
  {
    question: 'How long does solar installation take in Las Vegas?',
    answer: 'From signed contract to system activation, most Las Vegas installs take 4–8 weeks. The physical installation takes 1–2 days. The remaining time covers city permits (1–2 weeks), HOA approval if applicable (1–3 weeks), and NV Energy interconnection approval (1–2 weeks). Daniel coordinates all of this for you — you just show up for the install day.',
  },
  {
    question: 'Does Daniel serve California homeowners?',
    answer: 'Yes — Daniel is licensed to serve homeowners throughout Southern California, including Los Angeles, San Diego, and Riverside. California solar operates under NEM 3.0 (Net Billing Tariff), which changed how excess energy is credited starting in April 2023. Daniel specializes in designing California systems that maximize self-consumption and battery storage to optimize savings under the new rate structure.',
  },
];

const serviceAreas = [
  { name: 'Las Vegas, NV', href: '/solar-las-vegas' },
  { name: 'Henderson, NV', href: '/solar-henderson-nv' },
  { name: 'Summerlin, NV', href: '/solar-summerlin' },
  { name: 'Green Valley, NV', href: '/solar-henderson-green-valley' },
  { name: 'North Las Vegas, NV', href: '/solar-north-las-vegas' },
  { name: 'Los Angeles, CA', href: '/solar-los-angeles' },
  { name: 'San Diego, CA', href: '/solar-san-diego' },
  { name: 'Riverside, CA', href: '/solar-riverside' },
];
---

<BaseLayout
  title="Las Vegas Solar Agent — $0 Down Solar | Daniel Hadobas"
  description="Las Vegas solar specialist with 174 five-star Google reviews. $0 down solar with 30% federal tax credit. Honest math against your real NV Energy bill. Serving Las Vegas NV and California. Call (702) 941-6894."
  keywords="solar agent Las Vegas, solar panels Las Vegas NV, $0 down solar Las Vegas, Daniel Hadobas solar, NV Energy solar, federal solar tax credit Nevada, solar installation Las Vegas"
>
  <Fragment slot="schema">
    <PersonSchema />
    <LocalBusinessSchema city="Las Vegas" state="NV" slug="home" />
  </Fragment>

  <!-- Hero -->
  <Hero
    headline="Cut Your NV Energy Bill to Near Zero — $0 Down."
    subheadline="Daniel Hadobas runs the math against your real NV Energy bill — then tells you whether solar saves you money. 174 five-star reviews. Zero one-stars. Built entirely on referrals — no call center, no quotas."
    ctaText="See My Monthly Savings"
    ctaHref="/#get-quote"
  />

  <!-- Stats Bar (full-bleed dark anchor) -->
  <StatsBar stats={stats} />

  <!-- How It Works -->
  <HowItWorks
    headline="Go Solar in 3 Simple Steps"
    steps={howItWorksSteps}
  />

  <!-- Why Daniel -->
  <WhyDaniel headline="Why Las Vegas Homeowners Choose Daniel" />

  <!-- Reviews -->
  <section class="py-16 bg-[#FAFAF8]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <div class="section-divider mx-auto mb-4"></div>
        <h2 class="text-3xl font-bold text-slate-900">Trusted by Las Vegas Homeowners</h2>
        <p class="text-slate-500 mt-2 max-w-xl mx-auto">Real reviews from real people who made the switch with Daniel.</p>
      </div>
      <ReviewWidget />
    </div>
  </section>

  <!-- Talk to Daniel — Trust + Trustpilot critic quote -->
  <section class="py-20 border-y border-[#DDE3D8]" style="background-color:#F0F2EE;background-image:radial-gradient(circle at 30% 50%, rgba(106,183,69,0.08) 0%, transparent 60%);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="relative">
          <img
            src="/images/daniel-with-customer.jpg"
            alt="Daniel Hadobas reviewing a solar quote at a customer's kitchen table in Las Vegas"
            class="w-full h-auto rounded-2xl shadow-xl"
            loading="lazy"
          />
          <div class="absolute -bottom-5 -right-5 bg-[#6AB745] text-white rounded-xl px-5 py-3 shadow-lg hidden sm:block">
            <p class="text-xs font-semibold uppercase tracking-wider opacity-90">Top 1% Nationally</p>
            <p class="font-bold text-sm">178 installs / yr</p>
          </div>
        </div>
        <div>
          <p class="text-[#6AB745] font-semibold text-sm uppercase tracking-widest mb-3">No Call Center. No Quotas.</p>
          <h2 class="text-3xl sm:text-4xl text-slate-900 mb-6 leading-tight">Daniel comes to your kitchen table — and tells you the truth.</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Most solar reps work for a call center, hit a quota, and disappear after the install. Daniel doesn't. He's been a Las Vegas resident since 1996, put solar on his own home in 2015, and has built his entire business on referrals from happy neighbors.
          </p>
          <blockquote class="border-l-4 border-[#6AB745] pl-5 py-2 mb-6 bg-slate-50 rounded-r-lg">
            <p class="text-slate-900 text-lg font-medium italic mb-2">
              "The salesman Daniel was great — no pressure, very knowledgeable, and friendly."
            </p>
            <footer class="text-slate-500 text-sm">
              — Rod D., verified Las Vegas customer
              <span class="block text-xs mt-1">Posted on Trustpilot — a critical review of the office staff that still went out of its way to praise Daniel by name.</span>
            </footer>
          </blockquote>
          <a href="/#get-quote" class="inline-flex items-center gap-2 bg-[#6AB745] text-white px-7 py-3.5 rounded-lg font-bold cta-glow">
            See My Monthly Savings
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 bg-[#FAFAF8]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <div class="section-divider mx-auto mb-4"></div>
        <h2 class="text-3xl font-bold text-slate-900">Service Areas</h2>
        <p class="text-slate-500 mt-2">Daniel serves homeowners across Nevada and California</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-w-2xl mx-auto">
        {serviceAreas.map((area) => (
          <a
            href={area.href}
            class="flex items-center gap-2 bg-[#FAFAF8] hover:bg-white border border-slate-200 hover:border-brand-orange rounded-xl px-4 py-3 text-sm font-medium text-slate-700 hover:text-brand-orange transition-all duration-200 group"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500 group-hover:text-brand-orange" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {area.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Lead Form -->
  <LeadForm />

  <!-- FAQ -->
  <FAQSection faqs={homeFaqs} heading="Solar FAQs for Las Vegas Homeowners" />

  <!-- Final CTA -->
  <SectionCTA
    headline="Talk to Daniel — Not a Call Center."
    subheadline="If solar doesn't save you money, he'll tell you on the call. No pressure. No quotas. Just the math for your home, your roof, your NV Energy bill."
    buttonText="See My Monthly Savings"
    buttonHref="/#get-quote"
  />
</BaseLayout>
