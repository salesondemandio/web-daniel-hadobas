---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import PersonSchema from '../components/PersonSchema.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import StatsBar from '../components/StatsBar.astro';
import FAQSection from '../components/FAQSection.astro';
import ReviewWidget from '../components/ReviewWidget.astro';
import { riversideContent as c } from '../data/content/cities/riverside';
---

<BaseLayout title={c.meta.title} description={c.meta.description}>
  <Fragment slot="schema">
    <PersonSchema />
    <LocalBusinessSchema city="Riverside" state="CA" description={c.meta.description} />
  </Fragment>

  <section class="bg-brand-dark py-20 px-4 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-dark to-slate-800 opacity-50" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-brand-orange/20 border border-brand-orange/30 text-brand-orange rounded-full px-4 py-1.5 text-xs font-semibold mb-6">
        ⭐ 174 Five-Star Reviews · Serving Riverside, CA
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-black text-white mb-4 leading-[1.1]">{c.hero.h1}</h1>
      <p class="text-slate-300 text-lg max-w-xl mb-8 leading-relaxed">{c.hero.subheadline}</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <CTAButton text={c.cta.buttonText} size="lg" />
        <a href="tel:7027654527" class="inline-flex items-center gap-2 text-white font-semibold hover:text-brand-orange transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 017 2.18 2 2 0 019.09 4v3.09a2 2 0 01-1.42 1.93l-1.8.6a16 16 0 006.62 6.62l.6-1.8a2 2 0 011.92-1.42z"/></svg>
          (702) 765-4527
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <StatsBar stats={c.stats} />
  </section>

  <section class="py-12 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-dark mb-2">Riverside's Solar Expert — Independent, Trusted, 174 Five-Star Reviews</h2>
      <p class="text-brand-orange font-semibold mb-6">Daniel Hadobas · Licensed Solar Agent · SCE Rate Specialist</p>
      {c.intro.map((para: string) => (
        <p class="text-slate-600 leading-relaxed mb-4">{para}</p>
      ))}
    </div>
  </section>

  <section class="py-12 px-4 bg-slate-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-dark mb-8">Solar Incentives — Riverside, CA</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {c.incentives.map((inc: any) => (
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <h3 class="font-semibold text-brand-dark mb-2">{inc.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{inc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-10 px-4 bg-white">
    <div class="max-w-4xl mx-auto"><ReviewWidget /></div>
  </section>

  <FAQSection faqs={c.faqs} heading="Solar FAQs — Riverside, CA" />

  <section class="bg-brand-dark py-16 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-white mb-4">{c.cta.headline}</h2>
      <p class="text-slate-300 mb-8">{c.cta.subheadline}</p>
      <CTAButton text={c.cta.buttonText} size="lg" />
    </div>
  </section>
</BaseLayout>
