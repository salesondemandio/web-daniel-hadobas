---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import PersonSchema from '../components/PersonSchema.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import FAQSection from '../components/FAQSection.astro';
import ReviewWidget from '../components/ReviewWidget.astro';
import { californiaContent as c } from '../data/content/cities/california';
---

<BaseLayout title={c.meta.title} description={c.meta.description} keywords={c.meta.keywords}>
  <Fragment slot="schema">
    <PersonSchema />
    <LocalBusinessSchema city="Los Angeles" state="CA" description={c.meta.description} />
  </Fragment>

  <section class="bg-[#FAFAF8] py-20 px-4 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#F0F2EE] to-white opacity-50" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-brand-orange/20 border border-brand-orange/30 text-brand-orange rounded-full px-4 py-1.5 text-xs font-semibold mb-6">
        ⭐ 174 Five-Star Reviews · Serving Los Angeles, San Diego &amp; Riverside
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-black text-slate-900 mb-4 leading-[1.1]">{c.hero.h1}</h1>
      <p class="text-slate-600 text-lg max-w-xl mb-8 leading-relaxed">{c.hero.subheadline}</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <CTAButton text={c.cta.buttonText} size="lg" />
        <a href="tel:+17029416894" class="inline-flex items-center gap-2 text-slate-900 font-semibold hover:text-brand-orange transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 017 2.18 2 2 0 019.09 4v3.09a2 2 0 01-1.42 1.93l-1.8.6a16 16 0 006.62 6.62l.6-1.8a2 2 0 011.92-1.42z"/></svg>
          (702) 941-6894
        </a>
      </div>
    </div>
  </section>

  <section class="bg-white py-12 px-4 border-y border-[#E8ECE4]">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
      <img src="/images/daniel.jpg" alt="Daniel Hadobas — solar agent serving California homeowners" class="w-full max-w-sm rounded-2xl border border-[#E8ECE4] shadow-[0_8px_32px_rgba(5,7,8,0.08)] mx-auto" loading="lazy" width="500" height="500" />
      <div>
        <p class="text-[#6AB745] font-semibold text-sm uppercase tracking-widest mb-2">Your Independent Expert</p>
        <h2 class="font-display text-3xl text-slate-900 mb-3 leading-tight">Daniel works for you — not a marketplace.</h2>
        <p class="text-slate-600 leading-relaxed">Top 1% nationally. 174 five-star reviews. Specializes in NEM 3.0 systems sized for self-consumption + battery storage so you keep the savings California changed the rules on.</p>
      </div>
    </div>
  </section>

  <section class="py-12 px-4 bg-[#FAFAF8]">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-900 mb-2">California Solar Expert — Licensed Agent, Real Results</h2>
      <p class="text-brand-orange font-semibold mb-6">Daniel Hadobas · 174 Five-Star Google Reviews · Independent Solar Advisor</p>
      {c.intro.map((para: string) => (
        <p class="text-slate-600 leading-relaxed mb-4">{para}</p>
      ))}
    </div>
  </section>

  <section class="py-12 px-4 bg-amber-50 border-y border-amber-500/20">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-start gap-4">
        <div class="shrink-0 w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center mt-1">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div>
          <h2 class="text-xl font-bold text-slate-900 mb-3">{c.nem3Explainer.headline}</h2>
          <p class="text-slate-700 leading-relaxed">{c.nem3Explainer.body}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 px-4 bg-[#FAFAF8]">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-900 mb-8">California Service Areas</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {c.cities.map((city: any) => (
          <a href={`/${city.slug}`} class="group block bg-[#FAFAF8] hover:bg-brand-orange/5 border border-slate-200 hover:border-brand-orange rounded-xl p-6 transition-all duration-200">
            <h3 class="font-bold text-slate-900 group-hover:text-brand-orange mb-2">{city.name}, CA</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{city.description}</p>
            <span class="inline-flex items-center gap-1 text-brand-orange text-sm font-semibold mt-4">View solar guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-10 px-4 bg-[#FAFAF8]">
    <div class="max-w-4xl mx-auto"><ReviewWidget /></div>
  </section>

  <FAQSection faqs={c.faqs} heading="California Solar FAQs" />

  <section class="bg-[#FAFAF8] py-16 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-slate-900 mb-4">{c.cta.headline}</h2>
      <p class="text-slate-600 mb-8">{c.cta.subheadline}</p>
      <CTAButton text={c.cta.buttonText} size="lg" />
    </div>
  </section>
</BaseLayout>
