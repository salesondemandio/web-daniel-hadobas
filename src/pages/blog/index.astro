---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import { blogPosts } from '../../data/blog-posts';

const allTags = [...new Set(blogPosts.flatMap((p) => p.tags))].sort();
---

<BaseLayout
  title="Solar Energy Blog | Daniel Hadobas Solar"
  description="Expert solar energy advice for Las Vegas and California homeowners. Tax credits, net metering, cost breakdowns, and installation guides."
  keywords="solar energy blog, Las Vegas solar tips, California solar guide, solar tax credit guide, NV Energy net metering, solar installation advice"
>
  <!-- Hero -->
  <section class="bg-brand-dark py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="section-divider mx-auto mb-6"></div>
      <h1 class="font-display text-4xl sm:text-5xl font-black text-white mb-3">
        Solar <span class="text-brand-orange">Energy Blog</span>
      </h1>
      <p class="text-slate-300 text-lg max-w-xl mx-auto">
        Expert guides for Las Vegas and California homeowners going solar — tax credits,
        net metering, cost breakdowns, and real-world savings stories.
      </p>
    </div>
  </section>

  <!-- Tag filter -->
  <section class="bg-white border-b border-slate-100 py-4 px-4 sticky top-16 z-10">
    <div class="max-w-4xl mx-auto flex flex-wrap gap-2 items-center">
      <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider mr-1">Filter:</span>
      <a
        href="/blog"
        class="tag-pill px-3 py-1.5 rounded-full text-xs font-semibold border transition-all bg-brand-orange text-white border-brand-orange"
        id="tag-all"
      >All</a>
      {allTags.map((tag) => (
        <button
          class="tag-pill px-3 py-1.5 rounded-full text-xs font-semibold border border-slate-200 text-slate-600 hover:border-brand-orange hover:text-brand-orange transition-all bg-white"
          data-tag={tag}
        >{tag}</button>
      ))}
    </div>
  </section>

  <!-- Post list -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="grid gap-6" id="post-list">
        {blogPosts.map((post) => (
          <article
            class="group bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden"
            data-tags={post.tags.join(',')}
          >
            <a href={`/blog/${post.slug}`} class="block p-6 sm:p-8 flex flex-col sm:flex-row gap-4 sm:gap-6 items-start">
              <!-- Icon -->
              <div class="shrink-0 w-12 h-12 rounded-xl bg-brand-orange/10 flex items-center justify-center">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
              </div>

              <!-- Content -->
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <time datetime={post.publishDate} class="text-xs text-slate-400">{new Date(post.publishDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
                  {post.tags.map((tag) => (
                    <span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 text-xs font-medium">{tag}</span>
                  ))}
                </div>
                <h2 class="font-display font-bold text-xl text-brand-dark group-hover:text-brand-orange transition-colors mb-2">
                  {post.title}
                </h2>
                <p class="text-slate-500 text-sm leading-relaxed">{post.description}</p>
                <div class="mt-4">
                  <span class="inline-flex items-center gap-1 text-brand-orange text-sm font-semibold">
                    Read article
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-slate-50 py-16 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-2xl font-bold text-brand-dark mb-3">
        Ready to Go Solar?
      </h2>
      <p class="text-slate-500 mb-8">Get your free savings analysis from Daniel — no commitment required.</p>
      <CTAButton text="Get Free Savings Quote" size="lg" />
    </div>
  </section>
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLElement>('.tag-pill[data-tag]');
  const allPill = document.getElementById('tag-all') as HTMLAnchorElement;
  const posts = document.querySelectorAll<HTMLElement>('#post-list article');

  function activate(activeTag: string | null) {
    // pill styles
    allPill.className = allPill.className.replace('bg-brand-orange text-white border-brand-orange', 'bg-white text-slate-600 border-slate-200');
    pills.forEach((p) => {
      p.className = p.className.replace('bg-brand-orange text-white border-brand-orange', 'bg-white text-slate-600 border-slate-200');
    });
    if (!activeTag) {
      allPill.className = allPill.className.replace('bg-white text-slate-600 border-slate-200', 'bg-brand-orange text-white border-brand-orange');
    } else {
      pills.forEach((p) => {
        if (p.dataset.tag === activeTag) {
          p.className = p.className.replace('bg-white text-slate-600 border-slate-200', 'bg-brand-orange text-white border-brand-orange');
        }
      });
    }
    // show/hide posts
    posts.forEach((article) => {
      const tags = article.dataset.tags?.split(',') ?? [];
      article.style.display = (!activeTag || tags.includes(activeTag)) ? '' : 'none';
    });
  }

  pills.forEach((p) => {
    p.addEventListener('click', () => activate(p.dataset.tag ?? null));
  });
  allPill.addEventListener('click', (e) => { e.preventDefault(); activate(null); });
</script>
