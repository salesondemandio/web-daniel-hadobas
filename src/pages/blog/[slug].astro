---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import PersonSchema from '../../components/PersonSchema.astro';
import FAQSection from '../../components/FAQSection.astro';
import { blogPosts } from '../../data/blog-posts';

export function getStaticPaths() {
  return blogPosts.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
---

<BaseLayout title={`${post.title} | Daniel Hadobas Solar`} description={post.description} keywords={post.tags.join(', ') + ', solar Las Vegas, Daniel Hadobas solar'} ogType="article">
  <Fragment slot="schema">
    <PersonSchema />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["BlogPosting", "Article"],
      "headline": post.title,
      "description": post.description,
      "datePublished": post.publishDate,
      "dateModified": post.publishDate,
      "author": {
        "@type": "Person",
        "name": "Daniel Hadobas",
        "url": "https://danielhadobas.com/about",
        "jobTitle": "Licensed Solar Energy Specialist"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Daniel Hadobas Solar",
        "url": "https://danielhadobas.com",
        "logo": { "@type": "ImageObject", "url": "https://danielhadobas.com/favicon.svg" }
      },
      "image": "https://danielhadobas.com/og-v2.jpg",
      "url": `https://danielhadobas.com/blog/${post.slug}`,
      "mainEntityOfPage": { "@type": "WebPage", "@id": `https://danielhadobas.com/blog/${post.slug}` },
      "keywords": post.tags.join(", "),
      "articleSection": "Solar Energy",
      "inLanguage": "en-US",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", ".prose p:first-of-type"]
      }
    })} />
  </Fragment>

  <!-- Header -->
  <section class="bg-[#FAFAF8] py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <a href="/blog" class="inline-flex items-center gap-2 text-slate-500 hover:text-brand-orange text-sm mb-6 transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to Blog
      </a>
      <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500 mb-4">
        <time datetime={post.publishDate}>{new Date(post.publishDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
        <span>·</span>
        <span>By Daniel Hadobas</span>
        {post.tags.map((tag) => (
          <span class="ml-1 px-2 py-0.5 rounded-full bg-[#FAFAF8]/5 text-slate-600 font-medium">{tag}</span>
        ))}
      </div>
      <h1 class="font-display text-3xl sm:text-4xl font-black text-slate-900 leading-tight mb-4">{post.title}</h1>
      <p class="text-slate-600 text-lg leading-relaxed">{post.description}</p>
    </div>
  </section>

  <!-- Author bar -->
  <div class="bg-[#FAFAF8] border-b border-slate-200">
    <div class="max-w-3xl mx-auto px-4 py-4 flex items-center gap-4">
      <img src="/images/daniel-hadobas.jpg" alt="Daniel Hadobas" class="w-10 h-10 rounded-full object-cover bg-amber-100" width="40" height="40" />
      <div>
        <p class="font-semibold text-slate-900 text-sm">Daniel Hadobas</p>
        <p class="text-slate-500 text-xs">Licensed Solar Energy Specialist · 174 Five-Star Reviews</p>
      </div>
      <div class="ml-auto">
        <CTAButton text="See My Savings" size="sm" />
      </div>
    </div>
  </div>

  <!-- Article body -->
  <article class="py-12 px-4">
    <div class="max-w-3xl mx-auto prose prose-slate prose-headings:font-display prose-headings:text-slate-900 prose-a:text-brand-orange prose-strong:text-slate-900 max-w-none" set:html={post.body} />
  </article>

  <!-- FAQs -->
  {post.faqs && post.faqs.length > 0 && (
    <FAQSection faqs={post.faqs} heading="Frequently Asked Questions" />
  )}

  <!-- CTA -->
  <section class="bg-[#FAFAF8] py-16 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-slate-900 mb-4">Ready to Go Solar?</h2>
      <p class="text-slate-600 mb-8">Get your free savings analysis from Daniel — no commitment required.</p>
      <CTAButton text="See My Monthly Savings" size="lg" />
    </div>
  </section>
</BaseLayout>
